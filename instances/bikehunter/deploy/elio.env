# /etc/default/elio — environment for elio-orchester.service (systemd format).
# Same convention as /etc/default/bikehunter.

PORT=3001
# Shared instance token — every employee request presents this via the Rails
# layout meta tag. Generate: openssl rand -hex 32
ELIO_API_TOKEN=CHANGE-ME
ELIO_DB_NAME=bikehunter.db
ELIO_INSTANCE_CONFIG=/opt/elio/instances/bikehunter/config.json
# Not needed when nginx proxies same-origin (/elio/api). Set only for a
# separate subdomain: ELIO_CORS_ORIGIN=https://backoffice.example.com
